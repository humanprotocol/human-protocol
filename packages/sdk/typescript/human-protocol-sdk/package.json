{
  "name": "@human-protocol/sdk",
  "description": "Human Protocol SDK",
  "version": "5.2.0",
  "files": [
    "src",
    "dist"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "clean": "tsc --build --clean && rm -rf ./dist",
    "build": "yarn clean && tsc --build",
    "docs:post": "ts-node scripts/postprocess-docs.ts",
    "build:doc": "typedoc && yarn docs:post",
    "test": "vitest -u",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write '**/*.{ts,json}'",
    "prepack": "[ \"${SKIP_PREPACK:-}\" = \"true\" ] && exit 0 || yarn build"
  },
  "repository": {
    "url": "https://github.com/humanprotocol/human-protocol.git",
    "directory": "packages/sdk/typescript/human-protocol-sdk"
  },
  "keywords": [
    "human-protocol",
    "sdk",
    "node",
    "typescript",
    "ethereum"
  ],
  "license": "MIT",
  "lint-staged": {
    "*.ts": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "dependencies": {
    "@human-protocol/core": "workspace:*",
    "axios": "^1.4.0",
    "ethers": "~6.15.0",
    "graphql": "^16.8.1",
    "graphql-request": "^7.3.4",
    "graphql-tag": "^2.12.6",
    "openpgp": "^6.2.2",
    "secp256k1": "^5.0.1",
    "validator": "^13.12.0",
    "vitest": "^3.0.9"
  },
  "devDependencies": {
    "@types/validator": "^13.15.4",
    "eslint": "^9.39.1",
    "eslint-plugin-jest": "^28.9.0",
    "eslint-plugin-prettier": "^5.2.1",
    "glob": "^13.0.0",
    "prettier": "^3.7.4",
    "ts-node": "^10.9.2",
    "typedoc": "^0.28.15",
    "typedoc-plugin-markdown": "^4.9.0",
    "typescript": "^5.8.3"
  }
}
